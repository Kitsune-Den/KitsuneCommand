# Configuration for tools/deploy.{sh,ps1}.
#
# Copy this file to .deploy.env (gitignored) and fill in the values
# for YOUR server. The deploy scripts read both this file and the
# process environment — anything already exported wins, useful for
# CI / one-off overrides.

# SSH host the panel runs on. Required.
KC_DEPLOY_HOST=

# SSH user with rights to chown files + restart the systemd unit.
# Default: root. Change if you've set up a deploy user with the
# narrower permissions.
# KC_DEPLOY_USER=root

# Remote 7DTD Mods/ directory. The KitsuneCommand subfolder lives
# inside this. Default: /home/ada/7d2d-server/Mods.
# KC_DEPLOY_MODS_PATH=/home/ada/7d2d-server/Mods

# Linux user that owns the mod files. The deploy chowns to this
# at the end so 7DTD (running as this user) can read everything.
# Default: ada.
# KC_DEPLOY_SERVICE_USER=ada

# systemd unit name to restart at the end. Default: 7daystodie.
# KC_DEPLOY_SERVICE_NAME=7daystodie
