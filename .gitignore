src/KitsuneCommand/7dtd-binaries/

# Environment files
.env
.env.local
.env.*.local

# Deploy script local config — has the host + (optionally) the
# deploy user. .deploy.env.example is the version-controlled template.
.deploy.env
frontend/.env.development
frontend/coverage/

# Decompiled reference files
localization_decompiled.cs
*.decompiled.cs
oscore-*.cs
ref-*.cs

# Claude
.claude/

# Release-signing private keys. Default location for setup-signing-key
# is ~/.keys/ which is outside the repo, but defend against a stray
# copy landing in the tree by accident. See docs/SIGNING.md.
*.key
.keys/
